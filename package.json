{
	"name": "openfoodfacts-explorer",
	"description": "Modern JavaScript frontend for Open Food Facts",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"license": "AGPL-3.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/openfoodfacts/openfoodfacts-explorer.git"
	},
	"engines": {
		"node": ">=20.0.0 <25"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"format:changed": "pretty-quick --staged",
		"api:folksonomy": "openapi-typescript https://api.folksonomy.openfoodfacts.org/openapi.json --output src/lib/api/folksonomy.d.ts",
		"api:prices": "openapi-typescript https://prices.openfoodfacts.net/api/schema --output src/lib/api/prices.d.ts",
		"api": "pnpm run api:folksonomy && pnpm run api:prices",
		"prepare": "husky",
		"pre-commit": "pnpm format",
		"test": "vitest run --passWithNoTests"
	},
	"devDependencies": {
		"@crowdin/cli": "^4.14.3",
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/plus-jakarta-sans": "^5.2.8",
		"@formatjs/intl-durationformat": "^0.10.14",
		"@iconify-svelte/material-symbols": "^1.0.36",
		"@iconify-svelte/mdi": "^1.0.2",
		"@iconify-svelte/simple-icons": "^1.0.34",
		"@openfoodfacts/openfoodfacts-nodejs": "2.0.0-alpha.30",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.65.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "4.3.1",
		"@types/geojson": "^7946.0.16",
		"@types/leaflet": "^1.9.21",
		"@types/leaflet.markercluster": "^1.5.6",
		"@types/node": "^25.9.2",
		"@types/topojson-client": "^3.1.5",
		"@types/topojson-specification": "^1.0.5",
		"@typescript-eslint/eslint-plugin": "^8.60.1",
		"@typescript-eslint/parser": "^8.60.1",
		"@vercel/speed-insights": "^2.0.0",
		"cropperjs": "^2.1.1",
		"cytoscape": "^3.34.0",
		"daisyui": "5.5.20",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"fuse.js": "^7.4.2",
		"geojson": "^0.5.0",
		"globals": "^17.6.0",
		"html5-qrcode": "^2.3.8",
		"husky": "^9.1.7",
		"iso-3166-1": "^2.1.1",
		"iso-639-1": "^3.1.5",
		"isomorphic-dompurify": "^3.17.0",
		"jose": "^6.2.3",
		"jsbarcode": "^3.12.3",
		"leaflet": "^1.9.4",
		"leaflet.markercluster": "^1.5.3",
		"openapi-fetch": "^0.17.0",
		"openapi-typescript": "^7.13.0",
		"postcss": "^8.5.15",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"pretty-quick": "^4.2.2",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"svelte-eslint-parser": "^1.8.0",
		"svelte-i18n": "^4.0.1",
		"svelte-local-storage-store": "^0.6.4",
		"sveltekit-i18n": "^2.4.2",
		"tailwindcss": "^4.3.0",
		"tailwindcss-opentype": "^1.2.0",
		"topojson-client": "^3.1.0",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vega": "^6.2.0",
		"vega-lite": "^6.4.3",
		"vite": "^8.0.16",
		"vite-plugin-static-copy": "^4.1.1",
		"vitest": "^4.1.9",
		"world-atlas": "^2.0.2"
	},
	"dependencies": {
		"@openfoodfacts/openfoodfacts-webcomponents": "^1.16.0",
		"@sentry/sveltekit": "^10.57.0",
		"@webcomponents/webcomponentsjs": "^2.8.0"
	},
	"packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620"
}
