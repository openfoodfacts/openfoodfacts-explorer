{
	"name": "openfoodfacts-explorer",
	"description": "Modern JavaScript frontend for Open Food Facts",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"license": "AGPL-3.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/openfoodfacts/openfoodfacts-explorer.git"
	},
	"engines": {
		"node": ">=20.0.0 <25"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"format:changed": "pretty-quick --staged",
		"api:folksonomy": "openapi-typescript https://api.folksonomy.openfoodfacts.org/openapi.json --output src/lib/api/folksonomy.d.ts",
		"api:prices": "openapi-typescript https://prices.openfoodfacts.net/api/schema --output src/lib/api/prices.d.ts",
		"api": "pnpm run api:folksonomy && pnpm run api:prices",
		"prepare": "husky",
		"pre-commit": "pnpm format",
		"test": "vitest run --passWithNoTests"
	},
	"devDependencies": {
		"@crowdin/cli": "^4.12.0",
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/plus-jakarta-sans": "^5.2.8",
		"@formatjs/intl-durationformat": "^0.10.3",
		"@iconify-svelte/material-symbols": "^1.0.29",
		"@iconify-svelte/mdi": "^1.0.2",
		"@iconify-svelte/simple-icons": "^1.0.28",
		"@openfoodfacts/openfoodfacts-nodejs": "2.0.0-alpha.30",
		"@sinnwerkstatt/sveltekit-matomo": "github:VaiTon/sveltekit-matomo",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.49.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.4",
		"@types/geojson": "^7946.0.16",
		"@types/leaflet": "^1.9.21",
		"@types/leaflet.markercluster": "^1.5.6",
		"@types/topojson-client": "^3.1.5",
		"@types/topojson-specification": "^1.0.5",
		"@typescript-eslint/eslint-plugin": "^8.59.1",
		"@typescript-eslint/parser": "^8.59.1",
		"@vercel/speed-insights": "^1.3.1",
		"cropperjs": "^2.1.0",
		"cytoscape": "^3.33.1",
		"daisyui": "5.5.8",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"fuse.js": "^7.1.0",
		"geojson": "^0.5.0",
		"globals": "^16.5.0",
		"html5-qrcode": "^2.3.8",
		"husky": "^9.1.7",
		"iso-3166-1": "^2.1.1",
		"iso-639-1": "^3.1.5",
		"isomorphic-dompurify": "^3.1.0",
		"jose": "^6.1.3",
		"jsbarcode": "^3.12.1",
		"leaflet": "^1.9.4",
		"leaflet.markercluster": "^1.5.3",
		"openapi-fetch": "^0.15.0",
		"openapi-typescript": "^7.10.1",
		"postcss": "^8.5.6",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"pretty-quick": "^4.2.2",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.5",
		"svelte-eslint-parser": "^1.6.0",
		"svelte-i18n": "^4.0.1",
		"svelte-local-storage-store": "^0.6.4",
		"sveltekit-i18n": "^2.4.2",
		"tailwindcss": "^4.2.4",
		"tailwindcss-opentype": "^1.2.0",
		"topojson-client": "^3.1.0",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.59.1",
		"vega": "^6.2.0",
		"vega-lite": "^6.4.1",
		"vite": "^7.3.1",
		"vite-plugin-static-copy": "^3.2.0",
		"vitest": "^4.0.18",
		"world-atlas": "^2.0.2"
	},
	"dependencies": {
		"@openfoodfacts/openfoodfacts-webcomponents": "^1.15.1",
		"@sentry/sveltekit": "^10.29.0",
		"@webcomponents/webcomponentsjs": "^2.8.0"
	},
	"packageManager": "pnpm@11.0.5+sha512.94fa09e72016402aefce788e46994e18eb1922998b16b6fd5aa6bafd8ae4dea05d0852f60247fdb7d5ab8199a7b0beda830398f3f80cb9f822398522a1535481"
}
